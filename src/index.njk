---
layout: base.njk
isHome: true
navPrefix: ""
---
{% from "icons.njk" import icon %}

<!-- ===== Hero ===== -->
<section class="hero" id="top">
  <canvas id="constellation" aria-hidden="true"></canvas>
  <div class="hero-veil" aria-hidden="true"></div>
  <div class="hero-inner container">
    <div class="hero-grid">
      <div class="hero-copy">
        <p class="hero-eyebrow reveal">{{ site.eyebrow }}</p>
        <h1 class="hero-name reveal" data-delay="1">{{ site.nameTop }}<span class="ln2">{{ site.nameAccent }}</span></h1>
        <div class="hero-rule reveal" data-delay="2"></div>
        <p class="hero-role reveal" data-delay="2">{{ site.heroRole }}</p>
        <div class="hero-grant reveal" data-delay="3"><span class="star">★</span> <span>{{ site.grant }}</span></div>
        <div class="hero-chips reveal" data-delay="3">
          {% for c in site.chips %}<span>{{ c }}</span>{% endfor %}
        </div>
        <div class="hero-cta reveal" data-delay="4">
          <a href="#publications" class="btn btn--primary">Explore her work
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M5 12h14M13 6l6 6-6 6"/></svg></a>
          <a href="#about" class="btn btn--ghost">About Rezwana</a>
        </div>
      </div>
      <div class="hero-portrait reveal" data-delay="2">
        <div class="portrait-wrap">
          <div class="portrait-card">
            <img src="{{ site.portrait }}" alt="{{ site.nameTop }} {{ site.nameAccent }}, feminist anthropologist" width="880" height="1100" />
          </div>
          <span class="portrait-pill"><b>15+</b> yrs fieldwork</span>
          <div class="portrait-badge">
            <span class="bn">{{ site.bookBn }}</span>
            <small>{{ site.bookEn }}</small>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>

<!-- ===== About ===== -->
<section class="section" id="about">
  <div class="container">
    <div class="about-grid">
      <div class="about-aside reveal">
        <blockquote class="about-quote">{{ site.aboutQuote }}</blockquote>
        <img class="about-photo" src="{{ site.aboutPhoto }}" alt="{{ site.nameTop }} {{ site.nameAccent }}" width="900" height="900" loading="lazy" />
      </div>
      <div class="about-body reveal" data-delay="1">
        <div class="eyebrow" style="margin-bottom:1rem">About</div>
        {% for p in site.about %}<p>{{ p }}</p>{% endfor %}
        <div class="about-facts">
          <h3 class="facts-title">Current roles &amp; affiliations</h3>
          <ul class="fact-list">
            {% for r in site.roles %}<li><b>{{ r.role }}</b><span>{{ r.org }}</span></li>{% endfor %}
          </ul>
        </div>
        <div class="hero-cta" style="margin-top:1.8rem">
          <a href="/background/" class="btn btn--ghost">Full background &amp; CV
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M5 12h14M13 6l6 6-6 6"/></svg></a>
        </div>
      </div>
    </div>
  </div>
</section>

<!-- ===== Research ===== -->
<section class="section section--alt" id="research">
  <div class="container">
    <div class="section-head reveal">
      <div class="eyebrow">Research</div>
      <h2>Where my questions live</h2>
      <p class="lead">A decade and a half of fieldwork across the entanglements of gender, health, media, and the body in Bangladesh and beyond.</p>
    </div>
    <div class="grid research-grid">
      {% for r in research.items %}
      <article class="research-card reveal"{% if loop.index0 % 4 %} data-delay="{{ loop.index0 % 4 }}"{% endif %}>
        <div class="ic">{{ icon(r.icon) }}</div>
        <h3>{{ r.title | safe }}</h3><p>{{ r.body | safe }}</p>
      </article>
      {% endfor %}
    </div>
  </div>
</section>

<!-- ===== Teaching ===== -->
<section class="section" id="teaching">
  <div class="container">
    <div class="about-grid">
      <div class="section-head reveal sticky-head" style="margin-bottom:0">
        <div class="eyebrow">Teaching</div>
        <h2>In the classroom</h2>
        <p class="lead">{{ teaching.intro }}</p>
      </div>
      <div class="teach-list reveal" data-delay="1">
        {% for t in teaching.items %}
        <article class="teach-item">
          <div class="teach-top"><h3>{{ t.title }}</h3><span class="teach-level">{{ t.level }}</span></div>
          <p>{{ t.detail }}</p>
        </article>
        {% endfor %}
      </div>
    </div>
  </div>
</section>

<!-- ===== Publications ===== -->
<section class="section section--alt" id="publications">
  <div class="container">
    <div class="section-head reveal">
      <div class="eyebrow">Publications</div>
      <h2>Selected writing</h2>
      <p class="lead">Books, chapters, and peer-reviewed articles. Filter by type.</p>
    </div>
    {% set types = publications.items | pubTypes(true) %}
    <div class="filters reveal" role="tablist" aria-label="Filter publications">
      <button class="chip active" data-filter="all">All</button>
      {% for t in types %}<button class="chip" data-filter="{{ t | slugify }}">{{ t }}</button>{% endfor %}
    </div>
    <div class="pub-list">
      {% for p in publications.items %}{% if p.featured %}
      <article class="pub reveal" data-type="{{ p.type | slugify }}">
        <span class="year">{{ p.year }}</span>
        <div><h3>{{ p.title | safe }}</h3><p class="venue">{{ p.venue | safe }}</p></div>
        <span class="tag tag--{{ p.type | slugify }}">{{ p.type }}</span>
      </article>
      {% endif %}{% endfor %}
    </div>
    <div class="hero-cta reveal" style="margin-top:2rem">
      <a href="/publications/" class="btn btn--ghost">All publications &amp; citations
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M5 12h14M13 6l6 6-6 6"/></svg></a>
      <a href="{{ site.scholar }}" class="btn btn--ghost" rel="noopener" target="_blank">Google Scholar</a>
    </div>
  </div>
</section>

<!-- ===== Talks ===== -->
<section class="section" id="talks">
  <div class="container">
    <div class="about-grid">
      <div class="section-head reveal sticky-head" style="margin-bottom:0">
        <div class="eyebrow">Talks &amp; Keynotes</div>
        <h2>On stage &amp; in conversation</h2>
        <p class="lead">Recent invited lectures, keynotes, and conference presentations across three continents.</p>
        <div class="hero-cta" style="margin-top:1.6rem">
          <a href="{{ site.scholar }}" class="btn btn--ghost" target="_blank" rel="noopener">More on Scholar
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M7 17 17 7M9 7h8v8"/></svg></a>
        </div>
      </div>
      <div class="timeline reveal" data-delay="1">
        {% for t in talks.items %}
        {% if t.url %}<a class="tl-item" href="{{ t.url }}" target="_blank" rel="noopener">{% else %}<div class="tl-item">{% endif %}
          <div class="when">{{ t.when }}</div>
          <h3>{{ t.title | safe }}{% if t.url %} <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" width="14" height="14" style="vertical-align:middle;opacity:.6"><path d="M7 17 17 7M9 7h8v8"/></svg>{% endif %}</h3>
          <p class="where">{{ t.where | safe }}</p>
        {% if t.url %}</a>{% else %}</div>{% endif %}
        {% endfor %}
      </div>
    </div>
    <div class="gallery reveal" data-delay="1">
      {% for g in site.gallery %}
      <figure class="gallery-item"><img src="{{ g.image }}" alt="{{ g.caption }}" loading="lazy" /><figcaption>{{ g.caption }}</figcaption></figure>
      {% endfor %}
    </div>
  </div>
</section>

<!-- ===== Media & Public Engagement ===== -->
<section class="section section--alt" id="media">
  <div class="container">
    <div class="section-head reveal">
      <div class="eyebrow">Media &amp; Public Engagement</div>
      <h2>In the public conversation</h2>
      <p class="lead">Interviews, features, keynotes, and broadcast commentary translating ethnographic research into public debate.</p>
    </div>
    <div class="media-list reveal">
      {% for m in media.items %}
      {% if m.url %}<a class="media-item" href="{{ m.url }}" target="_blank" rel="noopener">{% else %}<div class="media-item">{% endif %}
        <div class="media-meta"><span class="media-outlet">{{ m.outlet }}</span><span class="media-year">{{ m.year }}</span></div>
        <h3>{{ m.title | safe }}</h3>
        <span class="media-type">{{ m.type }}{% if m.url %} <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" width="14" height="14"><path d="M7 17 17 7M9 7h8v8"/></svg>{% endif %}</span>
      {% if m.url %}</a>{% else %}</div>{% endif %}
      {% endfor %}
    </div>
  </div>
</section>

<!-- ===== Projects ===== -->
<section class="section" id="projects">
  <div class="container">
    <div class="section-head reveal">
      <div class="eyebrow">Current Projects</div>
      <h2>Research in motion</h2>
    </div>
    <div class="grid project-grid">
      {% for p in projects.items %}
      <article class="project-card reveal"{% if loop.index0 %} data-delay="{{ loop.index0 }}"{% endif %}>
        <div class="meta">{{ p.meta }}</div>
        <h3>{{ p.title | safe }}</h3>
        <p>{{ p.body | safe }}</p>
        <span class="role">{{ p.role }}</span>
      </article>
      {% endfor %}
    </div>
  </div>
</section>

<!-- ===== Recognition & Service ===== -->
<section class="section section--alt" id="recognition">
  <div class="container">
    <div class="section-head reveal">
      <div class="eyebrow">Recognition &amp; Service</div>
      <h2>Honours, peer review &amp; leadership</h2>
      <p class="lead">Beyond research and teaching — a record of national and international recognition, scholarly gatekeeping, and institutional leadership.</p>
    </div>
    <div class="grid info-grid">
      {% for g in recognition.groups %}
      <article class="info-card reveal"{% if loop.index0 %} data-delay="{{ loop.index0 }}"{% endif %}>
        <div class="info-ic">{{ icon(g.icon) }}</div>
        <h3>{{ g.title | safe }}</h3>
        <ul class="lined">
          {% for it in g.items %}<li><b>{{ it.name | safe }}</b>{% if it.detail %}<span>{{ it.detail | safe }}</span>{% endif %}</li>{% endfor %}
        </ul>
      </article>
      {% endfor %}
    </div>
  </div>
</section>

<!-- ===== Fieldwork map ===== -->
<section class="section" id="field">
  <div class="container">
    <div class="section-head reveal">
      <div class="eyebrow">Fieldwork &amp; Engagement</div>
      <h2>A research life on the map</h2>
    </div>
    <div class="map-wrap">
      <ul class="map-legend reveal">
        {% for f in fieldwork.items %}
        <li><span class="pin {{ 'plum' if f.color == 'plum' else ('teal' if f.color == 'teal' else '') }}"></span><div><strong>{{ f.name }}</strong><span>{{ f.note | safe }}</span></div></li>
        {% endfor %}
      </ul>
      <div id="fieldmap" class="reveal" data-delay="1" role="img" aria-label="World map of fieldwork and engagement sites"></div>
    </div>
  </div>
</section>
<script>window.FIELDWORK = {{ fieldwork.items | dump | safe }};</script>

<!-- ===== Training & Capacity Building ===== -->
<section class="section section--alt" id="training-capacity-building">
  <div class="container">
    <div class="section-head reveal">
      <div class="eyebrow">{{ training.eyebrow or "Training" }}</div>
      <h2>Training &amp; Capacity Building</h2>
      {% if training.lead %}<p class="lead">{{ training.lead }}</p>{% endif %}
    </div>
    <div class="teach-list reveal">
      {% for item in training.items %}
      <article class="teach-item">
        <div class="teach-top">
          <h3>{% if item.url %}<a href="{{ item.url }}" target="_blank" rel="noopener" style="color:inherit">{{ item.title | safe }}</a>{% else %}{{ item.title | safe }}{% endif %}</h3>
          {% if item.tag %}<span class="teach-level">{{ item.tag }}</span>{% endif %}
        </div>
        {% if item.subtitle %}<p style="font-size:var(--step--1);color:var(--terracotta);font-weight:600;margin:.2rem 0 .4rem">{{ item.subtitle }}</p>{% endif %}
        {% if item.detail %}<p>{{ item.detail | safe }}</p>{% endif %}
      </article>
      {% endfor %}
    </div>
  </div>
</section>

<!-- ===== Extra Sections (future use) ===== -->
{% for sec in custom_sections.sections %}
<section class="section{% if sec.style == 'alt' %} section--alt{% endif %}" id="{{ sec.title | slugify }}">
  <div class="container">
    <div class="section-head reveal">
      {% if sec.eyebrow %}<div class="eyebrow">{{ sec.eyebrow }}</div>{% endif %}
      <h2>{{ sec.title }}</h2>
      {% if sec.lead %}<p class="lead">{{ sec.lead }}</p>{% endif %}
    </div>
    {% if sec.layout == "timeline" %}
    <div class="about-grid">
      <div class="timeline reveal" data-delay="1">
        {% for item in sec.items %}
        {% if item.url %}<a class="tl-item" href="{{ item.url }}" target="_blank" rel="noopener">{% else %}<div class="tl-item">{% endif %}
          {% if item.subtitle %}<div class="when">{{ item.subtitle }}</div>{% endif %}
          <h3>{{ item.title | safe }}{% if item.url %} <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" width="14" height="14" style="vertical-align:middle;opacity:.6"><path d="M7 17 17 7M9 7h8v8"/></svg>{% endif %}</h3>
          {% if item.detail %}<p class="where">{{ item.detail | safe }}</p>{% endif %}
        {% if item.url %}</a>{% else %}</div>{% endif %}
        {% endfor %}
      </div>
    </div>
    {% elif sec.layout == "grid" %}
    <div class="grid project-grid">
      {% for item in sec.items %}
      <article class="project-card reveal"{% if loop.index0 %} data-delay="{{ loop.index0 }}"{% endif %}>
        {% if item.subtitle %}<div class="meta">{{ item.subtitle }}</div>{% endif %}
        <h3>{% if item.url %}<a href="{{ item.url }}" target="_blank" rel="noopener" style="color:inherit">{{ item.title | safe }}</a>{% else %}{{ item.title | safe }}{% endif %}</h3>
        {% if item.detail %}<p>{{ item.detail | safe }}</p>{% endif %}
        {% if item.tag %}<span class="role">{{ item.tag }}</span>{% endif %}
      </article>
      {% endfor %}
    </div>
    {% else %}
    <div class="teach-list reveal">
      {% for item in sec.items %}
      <article class="teach-item">
        <div class="teach-top">
          <h3>{% if item.url %}<a href="{{ item.url }}" target="_blank" rel="noopener" style="color:inherit">{{ item.title | safe }}</a>{% else %}{{ item.title | safe }}{% endif %}</h3>
          {% if item.tag %}<span class="teach-level">{{ item.tag }}</span>{% endif %}
        </div>
        {% if item.subtitle %}<p style="font-size:var(--step--1);color:var(--terracotta);font-weight:600;margin:.2rem 0 .4rem">{{ item.subtitle }}</p>{% endif %}
        {% if item.detail %}<p>{{ item.detail | safe }}</p>{% endif %}
      </article>
      {% endfor %}
    </div>
    {% endif %}
  </div>
</section>
{% endfor %}

<!-- ===== Contact ===== -->
<section class="section" id="contact">
  <div class="container">
    <div class="contact reveal">
      <span class="ring r1" aria-hidden="true"></span><span class="ring r2" aria-hidden="true"></span>
      <div class="contact-grid">
        <div>
          <div class="eyebrow" style="color:var(--terracotta-2)">Contact</div>
          <h2>Let's start a conversation</h2>
          <p class="lead">For collaborations, supervision, talks, or media on gender, anthropology, and Bangladesh.</p>
          <a href="mailto:{{ site.email }}" class="mail">{{ site.email }}</a>
          <div class="socials">
            <a href="{{ site.scholar }}" target="_blank" rel="noopener" aria-label="Google Scholar"><svg viewBox="0 0 24 24" fill="currentColor"><path d="M12 2 1 8l11 6 9-4.9V16h2V8L12 2zm0 13.5L5 11v3.5C5 17 8.1 19 12 19s7-2 7-4.5V11l-7 4.5z"/></svg></a>
            <a href="{{ site.researchgate }}" target="_blank" rel="noopener" aria-label="ResearchGate"><svg viewBox="0 0 24 24" fill="currentColor"><path d="M8 6h2v12H8zm5 0h3a3 3 0 0 1 0 6h-1l2 6h-2l-2-6h-1v6h-2V6h3zm0 4h1a1 1 0 0 0 0-2h-1z"/></svg></a>
            <a href="{{ site.university }}" target="_blank" rel="noopener" aria-label="University profile"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M3 21h18M5 21V9l7-5 7 5v12M9 21v-6h6v6"/></svg></a>
          </div>
        </div>
        <div>
          <ul class="contact-info">
            <li><svg width="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M12 21s-7-4.5-7-10a7 7 0 0 1 14 0c0 5.5-7 10-7 10z"/><circle cx="12" cy="11" r="2.5"/></svg> {{ site.address }}</li>
            <li><svg width="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M22 16.9v3a2 2 0 0 1-2.2 2 19.8 19.8 0 0 1-8.6-3 19.5 19.5 0 0 1-6-6 19.8 19.8 0 0 1-3-8.6A2 2 0 0 1 4.1 2h3a2 2 0 0 1 2 1.7c.1 1 .4 1.9.7 2.8a2 2 0 0 1-.5 2.1L8.1 9.9a16 16 0 0 0 6 6l1.3-1.2a2 2 0 0 1 2.1-.5c.9.3 1.8.6 2.8.7a2 2 0 0 1 1.7 2z"/></svg> {{ site.phone }}</li>
            <li><svg width="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="3" y="5" width="18" height="14" rx="2"/><path d="m3 7 9 6 9-6"/></svg> {{ site.email }}</li>
          </ul>
        </div>
      </div>
    </div>
  </div>
</section>
